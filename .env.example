# Runtime
NODE_ENV=development
PORT=7000
# Comma-separated origins the API will accept CORS requests from.
# Local: http://localhost:3000
# Prod : https://www.umanandasiddha.in,https://portfolio.studio.umanandasiddha.in
CORS_ORIGINS=http://localhost:3000

# Database (shared between the NestJS app and dbmate CLI).
# `?sslmode=disable` is for the dbmate client — the `pg` driver tolerates it.
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio?sslmode=disable

# dbmate-only knobs (so a fresh `dbmate up` from anywhere finds the right paths)
DBMATE_MIGRATIONS_DIR=./db/migrations
DBMATE_SCHEMA_FILE=./db/schema.sql

# Redis (BullMQ — subscription email queue)
REDIS_URL=redis://localhost:6379

# Auth — JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-________
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-_______
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Owner / admin
OWNER_EMAIL=umanandasiddha243@gmail.com

# Public URLs (for links in emails)
# Local: http://localhost:3000 / http://localhost:7000
# Prod : https://www.umanandasiddha.in / https://portfolio.api.umanandasiddha.in
PUBLIC_BASE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:7000

# Resend (transactional email)
RESEND_API_KEY=re_xxx
MAIL_FROM_DOMAIN=example.com
MAIL_FROM_NAME=Umananda Siddha

# Firebase admin (Google sign-in verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Replace literal \n in the private key string with real newlines or escape them in the env
FIREBASE_PRIVATE_KEY=

# Sanity (read-only — webhook removed in favour of lazy upsert on first engagement)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-05-16
SANITY_READ_TOKEN=

# Cookie domain for the auth cookies (pa_access, pa_refresh).
# - Local dev: leave empty so cookies default to the request host (localhost).
# - Prod    : ".umanandasiddha.in" so cookies are shared between client
#             (www.umanandasiddha.in) and API (portfolio.api.umanandasiddha.in).
COOKIE_DOMAIN=
